# QRBag Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# 🔴 CRITICAL FOR PRODUCTION (COOLIFY)
# ============================================
# 
# 1. DATABASE PERSISTENCE:
#    In Coolify, you MUST configure a persistent volume at /app/data
#    Otherwise, all data (QR codes, users, messages) will be LOST on each deployment!
#
#    Coolify Configuration:
#    - Go to your application settings
#    - Add a "Persistent Volume" with path: /app/data
#    - Enable "Persist data between deployments"
#
# 2. DATABASE URL:
#    The database file is stored at /app/data/qrbag.db
#    Make sure the path matches your persistent volume!
#
# ============================================

# Database (SQLite - file path)
# For production: file:/app/data/qrbag.db (persistent)
# For development: file:./dev.db (local)
DATABASE_URL=file:/app/data/qrbag.db

# Base URL for your application
# IMPORTANT: Update this to your production URL
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# NextAuth Secret (generate a secure 32+ character string)
# You can use: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# PayPal Configuration
# Get your credentials from: https://developer.paypal.com/developer/applications/
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret

# Encryption Key (generate a secure 32+ character string)
# You can use: openssl rand -base64 32
ENCRYPTION_KEY=your-secure-encryption-key-here

# Optional: SMTP Email Configuration
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-smtp-password
# SMTP_FROM=noreply@qrbag.com
