# QRBag Environment Configuration
# Copy this file to .env and fill in your values

# Database (SQLite - file path)
DATABASE_URL=file:/app/data/custom.db

# Base URL for your application
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# NextAuth Secret (generate a secure 32+ character string)
# You can use: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# PayPal Configuration
# Get your credentials from: https://developer.paypal.com/developer/applications/
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret

# Encryption Key (generate a secure 32+ character string)
# You can use: openssl rand -base64 32
ENCRYPTION_KEY=your-secure-encryption-key-here

# Optional: SMTP Email Configuration
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-smtp-password
# SMTP_FROM=noreply@qrbag.com
